.nf
.Ft void
.Fo libcthreads_error_free
.Fa "libcthreads_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcthreads_error_fprint
.Fa "libcthreads_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcthreads_error_sprint
.Fa "libcthreads_error_t *error"
.Fa "char *string"
.Fa "size_t size"
